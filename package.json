{
  "name": "hello-angular-azdo",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:portal": "ng serve portal",
    "start:reporting": "ng serve reporting",
    "build": "ng build",
    "build:all": "nx run-many --target=build --all",
    "build:portal": "ng build portal",
    "build:reporting": "ng build reporting",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:all": "nx run-many --target=test --all",
    "test:portal": "ng test portal",
    "test:reporting": "ng test reporting",
    "test:coverage": "ng test --coverage --coverage-reporters=lcov --coverage-reporters=text-summary",
    "format:check": "prettier --check \"src/**/*.ts\" \"apps/**/*.ts\"",
    "test:e2e": "playwright test",
    "test:e2e:portal": "playwright test --config apps/portal/playwright.config.ts",
    "test:e2e:reporting": "playwright test --config apps/reporting/playwright.config.ts",
    "test:integration": "ng test --include=\"**/*.integration.spec.ts\"",
    "build:prod": "ng build --configuration production",
    "build:prod:all": "nx run-many --target=build --configuration=production --all",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/animations": "^21.2.1",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "date-fns": "^4.1.0",
    "fuse.js": "^7.1.0",
    "lodash-es": "^4.17.23",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@angular-devkit/core": "^21.2.1",
    "@angular-devkit/schematics": "^21.2.1",
    "@angular/build": "^21.2.1",
    "@angular/cli": "^21.2.1",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "^1.58.2",
    "@schematics/angular": "^21.2.1",
    "@types/lodash-es": "^4.17.12",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.0.0",
    "nx": "^22.5.4",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
